# Copy to .env and fill in. Never commit the real .env (it is gitignored).

# Neon Postgres connection string (Phase 1)
DATABASE_URL=

# The Odds API key — the-odds-api.com (Phase 2). Never call the live API in dev/tests.
ODDS_API_KEY=

# Long random string protecting POST /api/cron/snapshot; also a GitHub Actions secret (Phase 2)
CRON_SECRET=
